\f3\i 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 Rationale:
\f0\i0  This is the gold standard for tearing-free, low-latency racing. The driver-level V-Sync handles frame pacing more efficiently than the LMU engine.\
\pard\tx220\tx720\pardeftab720\li720\fi-720\sa200\partightenfactor0
\ls15\ilvl0
\f1\b \cf2 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
